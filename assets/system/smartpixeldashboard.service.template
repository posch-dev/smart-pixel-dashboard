[Unit]
Description=Smart Pixel Dashboard
After=bluetooth.target network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__WORKDIR__
ExecStartPre=-/usr/bin/bluetoothctl disconnect
ExecStart=__WORKDIR__/.venv/bin/python __WORKDIR__/startup.py
Restart=always
RestartSec=10
MemoryMax=250M
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
